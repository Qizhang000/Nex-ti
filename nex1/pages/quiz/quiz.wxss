.page {
  min-height: 100vh;
  padding: 32rpx 0;
  background:
    radial-gradient(circle at 15% 15%, rgba(255, 196, 230, 0.35), transparent 32%),
    radial-gradient(circle at 85% 10%, rgba(180, 202, 255, 0.35), transparent 30%),
    linear-gradient(145deg, #fdf2f8 0%, #eef2ff 45%, #f0f9ff 100%);
}

.container {
  width: 92vw;
  margin: 0 auto;
}

.card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 16rpx 36rpx rgba(120, 127, 168, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.85);
}

.title {
  margin-bottom: 10rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #1f2937;
}

.subtitle {
  margin-bottom: 28rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #5b647f;
}

.meta {
  margin-bottom: 22rpx;
}

.progress-text {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #334155;
}

.progress {
  width: 100%;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(203, 213, 225, 0.45);
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  width: 0;
  background: linear-gradient(90deg, #7c3aed 0%, #ec4899 100%);
}

.question-title {
  margin-bottom: 18rpx;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #1f2937;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-btn {
  padding: 20rpx 22rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  text-align: left;
  line-height: 1.45;
  color: #1f2a44;
  background: linear-gradient(135deg, #f5f3ff 0%, #fdf2f8 100%);
  border: 1px solid rgba(196, 181, 253, 0.6);
}

.actions {
  margin-top: 18rpx;
}

.primary-btn,
.secondary-btn {
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  font-size: 30rpx;
  line-height: 1.2;
}

.primary-btn {
  margin-top: 18rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed 0%, #ec4899 100%);
}

.secondary-btn {
  color: #1e293b;
  background: rgba(241, 245, 249, 0.95);
  border: 1px solid rgba(203, 213, 225, 0.85);
}

.result-area {
  margin-top: 8rpx;
}

.result-block {
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1px solid rgba(196, 181, 253, 0.35);
}

.hero-block {
  background: linear-gradient(125deg, rgba(245, 243, 255, 0.92) 0%, rgba(252, 231, 243, 0.92) 100%);
}

.block-label {
  font-size: 22rpx;
  letter-spacing: 0.08em;
  font-weight: 700;
  color: #7c3aed;
}

.result-title {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.45;
  color: #1f2937;
}

.result-desc {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #374151;
}

.section-title {
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #2d1b69;
}

.breakdown {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #faf5ff 0%, #fdf4ff 100%);
  border: 1px solid rgba(216, 180, 254, 0.32);
  font-size: 28rpx;
  line-height: 1.7;
  color: #334155;
}

.radar-canvas {
  width: 100%;
  height: 520rpx;
  margin-top: 12rpx;
}
